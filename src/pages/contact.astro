---
import { Image } from 'astro:assets';
import InstaLogo from '../images/InstaLogo.png';
import Header from '../components/Header.astro';
---

<style>
@import url('https://fonts.googleapis.com/css2?family=Anton&display=swap');

html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
}

.contact {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: #D0F8FF;
    display: flex;
    align-items: center;
    justify-content: center;
  }

.contact-text {
    text-align: center;
    line-height: 0.85;
    z-index: 2;
  }

.contact-text h1 {
    font-family: 'Anton', Impact, sans-serif;
    font-size: clamp(400px, 1px, 1px);
    text-transform: uppercase;
    margin: 0;
    letter-spacing: -3px;
  }

.contact-text h1 strong {
    color: #35220A;
    display: block;
  }

.contact-text h1 .sub {
    color: #35220A;
    display: block;
  }

.flowing-wrap {
    position: absolute;
    top: 50%;
    width: 110%;
    transform: rotate(-8deg);
    z-index: 3;
  }

.flowing-band {
    background: #FE9518;
    padding: 30px 0;
  }

.flowing-item {
    font-family: 'Anton', Impact, sans-serif;
    font-size: 18px;
    color: #35220A;
    text-transform: uppercase;
    padding: 0 24px;
    display: inline-flex;
    align-items: center;
    gap: 16px;
  }

.insta-link {
    position: absolute;
    bottom: 32px;
    right: 32px;
    z-index: 5;
  }

.insta-link img {
    width: 40px;
    height: 40px;
  }
</style>

<Header/>
<a href="mailto:Zyoshihara@gmail.com" style="display:contents;">
  <div class="contact">

    <div class="contact-text">
      <h1>
        <strong>Work</strong>
        <span class="sub">with me</span>
      </h1>
    </div>

    <div class="flowing-wrap">
      <div class="flowing-band">
        <div class="flowing-text">
          
        </div>
      </div>
    </div>

  </div>
</a>

<a href="https://www.instagram.com/zenibean/" target="_blank" class="insta-link">
  <Image src={InstaLogo} alt="Instagram" width={40} height={40} />
</a>