---
import { Image } from 'astro:assets';
import Logo from '../images/Logo.png';
---



<style>
  text{
    ;
  }
.middle-bar {
  color: #35220A;
  position: fixed;
  height: 100vh;
  width: 170px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: hsla(190, 88%, 68%, 0.9);
  backdrop-filter: blur(6px);
  z-index: 10;
}

.small-image img {
  height: 100px;
  width: 100px;
  display: block;
  object-fit: cover;
  margin: 0 auto;
  border-radius: 50%;
}
nav {
  display: flex;
  flex-direction: column;
  gap: 5px;
}
ul a {
  color: black;
  text-decoration: none;
  display: inline-block;
  padding: 0 1px;
  width: 120px;
  text-align: center;
}
.dropbtn {
  color: black;
  display: inline-block;
  width: 120px;
  text-align: center;
  cursor: pointer;
}
.dropdown-content {
  display: none;
  position: absolute;
}

.header {
  color: gray;
}
.header-distance {
  background: black;
  height: 1px;
}


</style>

<nav class='middle-bar'>
  <div class='small-image'>
    <a href=''>
      <Image src={Logo} alt={'Zenith.inc'} height={200} width={100}/>
    </a>
  </div>
  <ul>
    <li>
       <a id='dropdownButton' class='dropbtn'> Albums </a>
        <ul id='dropdownContent' class='dropdown-content'>
            <h1 class='header'>Film</h1>
            <div class='header-distance'>
            </div>
            <li class='button-distance'>
              <a href=''>Color</a>
            </li>
            <li class='button-distance'>
              <a href=''>B&W</a>
            </li>
            <h1 class='header'>Digital</h1>
            <li class='button-distance'>
              <a href=''>Nature</a>
            </li>
            <li class='button-distance'>
              <a href=''>Urban Landscape</a>
            </li>
            <div class='dropdown-end'>
            </div>
        </ul>
    </li>
    <li>
      <a href='/about'>About</a>
    </li>
    <li>
      <a href='/contact'>Contact</a>
    </li>
  </ul>
</nav>

